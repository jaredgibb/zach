rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          "zach@diversifiedpsychservices.com",
          "jared.gibb@gmail.com"
        ];
    }

    function isAdmin() {
      return isSignedIn()
        && (
          isSuperAdmin()
          || (
            get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "admin"
            && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active != false
          )
        );
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if false;
    }

    match /therapists/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
